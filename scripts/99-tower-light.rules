# /etc/udev/rules.d/99-tower-light.rules
#
# Creates a stable symlink /dev/tower-light for the Adafruit USB Tower Light
# (QinHeng CH340 serial converter, VID 1a86 PID 7523)
#
# Install:
#   sudo cp 99-tower-light.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#
# The API will autodetect the CH340 by VID/PID at runtime, but this symlink
# acts as a reliable fallback and makes the device path predictable in scripts.

SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", \
    SYMLINK+="tower-light", \
    MODE="0666", \
    TAG+="systemd"
